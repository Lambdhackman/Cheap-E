<Window Style="{StaticResource MaterialDesignWindow}"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:My_Project"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="My_Project.MainWindow"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="SearchBar" HorizontalAlignment="Left" Height="30" Margin="38,30,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="241" TextChanged="SearchBar_TextChanged"/>
        <Button x:Name="SearchButton" Content="Search product" HorizontalAlignment="Left" Height="30" Margin="284,30,0,0" VerticalAlignment="Top" Width="128" Click="SearchButton_Click"/>
        <ListBox x:Name="SearchCompletion" HorizontalAlignment="Left" Height="101" Margin="38,65,0,0" VerticalAlignment="Top" Width="241" d:ItemsSource="{d:SampleData ItemCount=5}" SelectionChanged="SearchCompletion_SelectionChanged" Loaded="SearchCompletion_Loaded"/>
        <Label x:Name="BestProduct" Content="The Best Product" HorizontalAlignment="Left" Height="30" Margin="548,30,0,0" VerticalAlignment="Top" Width="207"/>
        <TextBlock x:Name="ProductInfo" HorizontalAlignment="Left" Height="105" Margin="548,65,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="207"/>
        <Label x:Name="MarketLabel" Content="Store Information" HorizontalAlignment="Left" Height="42" Margin="548,217,0,0" VerticalAlignment="Top" Width="207"/>
        <TextBlock x:Name="MarketInformation" HorizontalAlignment="Left" Height="93" Margin="548,264,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="207"/>
        <Label x:Name="ShoppingLabel" Content="My shopping List" HorizontalAlignment="Left" Height="47" Margin="38,171,0,0" VerticalAlignment="Top" Width="241"/>
        <ListBox x:Name="ShoppingList" HorizontalAlignment="Left" Height="194" Margin="39,218,0,0" VerticalAlignment="Top" Width="239" d:ItemsSource="{d:SampleData ItemCount=5}" Loaded="ShoppingList_Loaded" SelectionChanged="ShoppingList_SelectionChanged"/>
        <Button x:Name="AddList" Content="Add to list" HorizontalAlignment="Left" Height="30" Margin="284,86,0,0" VerticalAlignment="Top" Width="128" Click="AddList_Click"/>
        <Button x:Name="SearchList" Content="Search List" HorizontalAlignment="Left" Height="30" Margin="284,218,0,0" VerticalAlignment="Top" Width="128" Click="SearchList_Click"/>
        <Button x:Name="DeleteButton" Content="Delete" HorizontalAlignment="Left" Height="30" Margin="284,253,0,0" VerticalAlignment="Top" Width="128" Click="DeleteButton_Click"/>
        <Label x:Name="BestList" Content="The Best List Price" HorizontalAlignment="Left" Height="30" Margin="548,30,0,0" VerticalAlignment="Top" Width="207"/>

    </Grid>

</Window>
